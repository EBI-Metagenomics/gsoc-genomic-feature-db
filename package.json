{
  "name": "genomic-search-poc",
  "private": true,
  "version": "0.1.0",
  "description": "Browser-based genomic feature search engine POC using SQLite WASM + FTS5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "index": "python scripts/indexer.py scripts/BU_ATCC8492_annotations.gff",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@sqlite.org/sqlite-wasm": "^3.51.2-build6",
    "@tailwindcss/vite": "^4.2.1",
    "coi-serviceworker": "^0.1.7",
    "comlink": "^4.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sqlite-wasm-http": "^1.2.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "gh-pages": "^6.3.0",
    "typescript": "^5.5.3",
    "vite": "^5.4.1"
  }
}
